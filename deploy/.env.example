# Tuis Configuration
# Copy to .env and adjust as needed

# Image version - pin to a specific version or use 'latest'
TUIS_VERSION=latest

# Host port for web interface
WEB_PORT=6969

# Google OAuth (from Google Cloud Console)
# 1. Create a project at https://console.cloud.google.com
# 2. Enable Google Calendar API
# 3. Configure OAuth consent screen
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Set redirect URI to match NEXTAUTH_URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Actual Budget API (for Quotes budget card)
ACTUAL_API_URL=http://localhost:3100

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Error tracking (opt-in) — works with Sentry or GlitchTip, just set the DSN.
# Leave empty or omit to disable error tracking entirely.
NEXT_PUBLIC_SENTRY_DSN=

# File uploads — max size in MB (default: 10)
# MAX_UPLOAD_SIZE_MB=10
